{
  "name": "swit-docs",
  "version": "1.0.0",
  "description": "Documentation website for Swit Go Microservice Framework",
  "scripts": {
    "dev": "vitepress dev",
    "build": "vitepress build",
    "preview": "vitepress preview",
    "generate-api-docs": "node scripts/api-docs-generator.js",
    "sync-docs": "node scripts/sync-docs.js",
    "build-all": "./scripts/build-all.sh",
    "build-optimized": "npm run build && npm run optimize",
    "optimize": "node scripts/performance-optimizer.js",
    "validate-content": "node scripts/content-validator.js",
    "clean": "rm -rf dist .vitepress/cache",
    "clean-all": "npm run clean && rm -rf node_modules package-lock.json",
    "lint": "echo 'Linting not configured yet'",
    "test": "echo 'Tests not configured yet'",
    "analyze": "npm run build && npm run optimize"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "vitepress": "^1.0.0-rc.31",
    "vue": "^3.3.10"
  },
  "dependencies": {
    "@vueuse/core": "^10.7.0",
    "shiki": "^0.14.7"
  }
}